# Host & Port Settings
PORT=3000
NODE_ENV=production

# Security & Tokens
# Generate a secure secret for token signatures. E.g. using openssl rand -hex 32
JWT_SECRET=your_super_stable_jwt_secret_key_change_me_in_production

# CORS Configuration
# Comma-separated list of allowed origins, or * for all
CORS_ORIGIN=*

# Rate Limiting
# 15 minutes window
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window
RATE_LIMIT_MAX=1000

# Directory and Database Storage Paths
# Absolute or relative path to JSON database file
DB_FILE_PATH=./db.json
# Path where user uploaded files (e.g., signatures, files) are stored
UPLOADS_DIR_PATH=./uploads
# Path where Excel/CSV sync files are stored
EXCEL_DIR_PATH=./excel_storage
# Path where automatic database backups are placed
BACKUP_DIR_PATH=./backups

# Automated Backups
# Set to true to enable automated periodic database backups
ENABLE_BACKUPS=true
# Backup interval in milliseconds (default: 86400000 ms = 24 hours)
BACKUP_INTERVAL_MS=86400000

# API Configuration (Frontend)
VITE_API_URL=https://your-production-domain.com
